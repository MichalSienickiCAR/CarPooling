# Django settings
# DEBUG and SECRET_KEY are handled in settings.py; set as needed
# DEBUG=True
# SECRET_KEY=your-secret-key

# Database configuration
# Use SQLite locally by default
DB_ENGINE=sqlite

# Uncomment and set these only if using Postgres
# DB_ENGINE=postgres
# DB_NAME=carpooling
# DB_USER=carpool
# DB_PASSWORD=your_postgres_password
# DB_HOST=localhost
# DB_PORT=5432
